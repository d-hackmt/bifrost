# Bifrost experiments — environment variables
# This file is gitignored — never commit it.

# --- OpenAI ---
OPENAI_API_KEY=

# --- Groq (LangChain agents) ---
GROQ_API_KEY=

# --- Mistral ---
MISTRAL_API_KEY=


# --- Qdrant Cloud (vector store) ---
# From your cluster dashboard at cloud.qdrant.io, e.g. https://xxxxxxxx.us-east-1-0.aws.cloud.qdrant.io:6333
QDRANT_URL=http
QDRANT_API_KEY=

# --- Jina (embeddings) ---
JINA_API_KEY=-

# --- Bifrost (self-hosted gateway, default: http://localhost:8080) ---
BIFROST_BASE_URL=http://localhost:8080
BIFROST_GROQ_VIRTUAL_KEY=
BIFROST_MISTRAL_VIRTUAL_KEY=



# --- Optional: OpenTelemetry ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
